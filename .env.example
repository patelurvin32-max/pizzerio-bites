# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Access token lifetime (default 15m) and refresh cookie lifetime in days (default 7)
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

# CSRF Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CSRF_SECRET=your-random-secret-string-here-32-chars-minimum

# Server Configuration
PORT=5000
NODE_ENV=production

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS — comma-separated origins allowed)
CLIENT_URL=https://your-vercel-app.vercel.app

# Enable default menu seed in production (set to true to enable)
ENABLE_DEFAULT_SEED=false
